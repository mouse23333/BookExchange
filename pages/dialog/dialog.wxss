/* pages/dialog/dialog.wxss */

.chat_content {
  margin-bottom: 120rpx;
  width: 100%;
  height: 100vh;
  padding-bottom: 100rpx;
}

/* 输入区域 */
.pub-comment {
  background-color: #F5F6F8;
  padding: 16rpx 30rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  position: fixed;
  bottom: 0;
  width: 750rpx;
  box-sizing: border-box;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.pub-left {
  flex: 1;
  background-color: #FFFFFF;
  border-radius: 50rpx;
  margin-right: 16rpx;
  border: 1rpx solid #E8E8E8;
}

.pub-input {
  padding: 12rpx 24rpx;
  font-size: 28rpx;
}

.pub-button {
  color: #FFFFFF;
  background-color: #2E7D32;
  border-radius: 50rpx;
  padding: 14rpx 36rpx;
  font-size: 28rpx;
  font-weight: bold;
  min-height: 44px;
  min-width: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 对话框 */
.dialogArea {
  width: 750rpx;
  height: auto;
  display: flex;
  flex-direction: column;
}

.dialogArea > .dialogRight {
  width: 590rpx;
  margin: 16rpx 20rpx;
  height: auto;
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  padding-left: 120rpx;
  align-items: flex-start;
}

.dialogArea > .dialogLeft {
  width: 590rpx;
  margin: 16rpx 20rpx;
  height: auto;
  display: flex;
  flex-direction: row;
  padding-right: 120rpx;
  align-items: flex-start;
}

.head {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

/* 对方气泡（左侧） - 浅绿色 */
.dialogLeft .bot {
  margin-left: 16rpx;
  margin-right: 20rpx;
  padding: 16rpx 24rpx;
  background-color: #E8F5E9;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* 自己气泡（右侧）- 绿色 */
.dialogRight .bot {
  margin-left: 20rpx;
  margin-right: 16rpx;
  padding: 16rpx 24rpx;
  background-color: #2E7D32;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(46, 125, 50, 0.2);
}

/* 对方文字 */
.dialogLeft .bot text {
  font-size: 30rpx;
  color: #1A1A1A;
  word-wrap: break-word;
  word-break: break-all;
  white-space: pre-line;
}

/* 自己文字 */
.dialogRight .bot text {
  font-size: 30rpx;
  color: #FFFFFF;
  word-wrap: break-word;
  word-break: break-all;
  white-space: pre-line;
}
