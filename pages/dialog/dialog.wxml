<view id="viewCommunicationBody">
<scroll-view scroll-y="true" scroll-into-view="{{scrollIntoView}}" scroll-with-animation="true" class='chat_content' >
  <view wx:for="{{dialogs}}" wx:key="index" id="msg-{{index}}" data-src="{{item}}" class="dialogArea">

    <!-- 如果是自己发出的消息-->
    <block wx:if="{{item.name==rightID}}">
      <view class="dialogRight">
        <view class="bot">
          <text>{{item.text}}</text>
        </view>
        <image class="head" src="{{rightHead}}"/>
      </view>
    </block>
    <!-- 如果是对方发出的消息 -->
    <block wx:if="{{item.name==leftID}}">
      <view class="dialogLeft">
      <image class="head" src="{{leftHead}}"/>
        <view class="bot">
          <text>{{item.text}}</text>
        </view>
      </view>
    </block>
  </view>
</scroll-view>
</view>

<view class="pub-comment">
  <view class="pub-left">
    <input class="pub-input" bindinput="input" value="{{inputText}}"></input>
  </view>
  <view class="pub-button" bindtap="publish" disabled="{{sending}}">发送</view>
</view>