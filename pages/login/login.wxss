/* pages/login/login.wxss */

/* 全页绿色渐变背景 */
.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F5F6F8 40%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Logo 区域 */
.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 120rpx;
}

.logo-image {
  height: 200rpx;
  width: 200rpx;
  border-radius: 50%;
  box-shadow: 0 4rpx 24rpx rgba(46, 125, 50, 0.3);
  border: 6rpx solid #FFFFFF;
}

.app-name {
  margin-top: 30rpx;
  font-size: 44rpx;
  font-weight: bold;
  color: var(--primary);
  letter-spacing: 6px;
}

.app-subtitle {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: var(--text-hint);
  letter-spacing: 2px;
}

/* 表单卡片 */
.form-card {
  width: 600rpx;
  background: var(--card);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  margin-top: 60rpx;
  padding: 40rpx 40rpx 30rpx;
}

.input-group {
  display: flex;
  align-items: center;
  height: 100rpx;
  border-bottom: 1rpx solid var(--border);
}

.input-group:last-of-type {
  border-bottom: none;
}

.input-label {
  color: var(--text-primary);
  font-size: 32rpx;
  font-weight: bold;
  width: 90rpx;
  flex-shrink: 0;
}

.input-box {
  flex: 1;
  margin-left: 20rpx;
}

.input-box input {
  font-size: 30rpx;
  color: var(--text-primary);
  width: 100%;
}

/* 按钮区 */
.btn-area {
  width: 600rpx;
  margin-top: 40rpx;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  background-color: var(--primary);
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: bold;
  letter-spacing: 4px;
  border-radius: var(--radius-btn);
  box-shadow: 0 4rpx 12rpx rgba(46, 125, 50, 0.3);
}

.register-btn {
  width: 100%;
  height: 88rpx;
  margin-top: 24rpx;
  background-color: transparent;
  color: var(--primary);
  font-size: 30rpx;
  letter-spacing: 4px;
  border: 2rpx solid var(--primary);
  border-radius: var(--radius-btn);
}

/* 底部提示 */
.footer-tip {
  margin-top: 50rpx;
  font-size: 24rpx;
  color: var(--text-hint);
  text-align: center;
}
