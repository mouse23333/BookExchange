<!-- 大标题 -->
<view class="page-title">发布书籍</view>

<!-- 上传图片 -->
<view class="upload-image-area">
  <view style="font-size: 28rpx; color: #888; margin-bottom: 20rpx;">上传书籍图片（至少一张）</view>
  <van-uploader
    file-list="{{ imageList }}"
    bind:after-read="afterRead"
    bind:delete="onDelete"
  />
</view>

<!-- 输入表单 -->
<view style="box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06); margin: 20rpx; border-radius: 16rpx; overflow: hidden;">
<van-cell-group>
  <van-field
    model:value="{{ titleInput }}"
    placeholder="书名 *"
    size="large"
    type="textarea"
    autosize
    required
    bind:change="titleChange"
  />
  <van-field
    model:value="{{ pressInput }}"
    placeholder="出版社"
    size="large"
    type="textarea"
    autosize
    bind:change="pressChange"
  />
  <van-field
    model:value="{{ authorInput }}"
    placeholder="作者"
    size="large"
    type="textarea"
    autosize
    bind:change="authorChange"
  />
  <van-field
    model:value="{{ ISBNInput }}"
    placeholder="ISBN 码"
    size="large"
    type="textarea"
    autosize
    bind:change="ISBNChange"
  />
  <van-field
    model:value="{{ priceInput }}"
    placeholder="售价 *"
    size="large"
    type="textarea"
    autosize
    required
    bind:change="priceChange"
  />
  <van-field
    model:value="{{ detailInput }}"
    placeholder="详细描述（新旧程度、有无笔记等）"
    size="large"
    type="textarea"
    autosize
    bind:change="describeChange"
  />
</van-cell-group>
</view>

<!-- 上传按钮 -->
<view style="padding: 40rpx 80rpx;">
  <button bind:tap="upload" loading="{{uploading}}" disabled="{{uploading}}" style="background-color: #2E7D32; color: #fff; border-radius: 12rpx; font-size: 34rpx; font-weight: bold; letter-spacing: 4px;">{{uploading ? '发布中...' : '发布'}}</button>
</view>
