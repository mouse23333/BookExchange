/* pages/message/message.wxss */

.messageArea {
  width: 750rpx;
  padding: 20rpx;
  background-color: #FFFFFF;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  border-bottom: 1rpx solid #F0F0F0;
}

.messageArea:active {
  background-color: #F5F6F8;
}

.messageImg {
  width: 160rpx;
  height: 200rpx;
  margin-right: 20rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.messageTextArea {
  flex: 1;
  height: 180rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
}

.MessageTitle {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A1A1A;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.MessageText {
  font-size: 26rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.messageUserSide {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  margin-left: 10rpx;
}

.messageUserHead {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  border: 2rpx solid #E8F5E9;
}

.unread-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background-color: #2E7D32;
  margin-top: 8rpx;
}

.message-role-tag {
  font-size: 20rpx;
  color: #FFFFFF;
  background-color: #2E7D32;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  margin-top: 6rpx;
}

.message-role-buyer {
  background-color: #FF8F00;
}
