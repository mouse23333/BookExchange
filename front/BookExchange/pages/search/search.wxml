<!-- 搜索框 -->
<!-- 注意搜索框颜色 -->
<van-search
  value="{{ value }}"
  placeholder="请输入搜索关键词"
  show-action
  bind:search="onSearch"
  use-action-slot="true"
  background="#F2F2F2"
><view slot="action" bind:tap="onSearch">搜索</view>
</van-search>

<!-- 回到顶端按钮 -->
<button class="backToTopButton" bind:tap="backToTop">
<text style="color:azure;font-size:24rpx;line-height:25rpx;column-width:25rpx;width:50rpx;height:50rpx">回到顶部</text>
</button>

<!-- 搜索结果 -->
<view class="findingInTotal">
  <!-- 单个 -->
  <view class="findingEvery" wx:for="{{infoList}}" wx:key="item">
    <!-- 图片 -->
    <image class="findingImg" src="{{item.image}}" mode="aspectFill" bind:tap="seeImage" data-src="{{item.image}}"/>
    <!-- 详细信息 -->
      <view class="findingInfo" bind:tap="navi" data-src="{{item}}">
        <view class="title">{{item.title}}</view>
        <view class="press">{{item.press}}</view>
        <text class="rmbIcon">￥</text>
        <text class="price">{{item.price}}</text>
      </view>
  </view>
</view>


