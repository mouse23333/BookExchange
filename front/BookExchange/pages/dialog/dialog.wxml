


<scroll-view scroll-y="true" scroll-into-view="{{last}}" scroll-with-animation="true" class='chat_content'>
  <view wx:for="{{dialogInfo.dialogs}}"  data-src="{{item}}" class="dialogArea">

    <!-- 如果是自己发出的消息 这里的userinfo要改-->
    <block wx:if="{{item.name==rightID}}">
      <view class="dialogRight">
        <view class="bot">
          <text>{{item.text}}</text>
        </view>
        <image class="head" src="自己的头像"/>
      </view>

    </block>
    <!-- 如果是对方发出的消息 -->
    <block wx:if="{{item.name==leftID}}">
      <view class="dialogLeft">
      <image class="head" src="对方头像"/>
        <view class="bot">
          <text>{{item.text}}</text>
        </view>
      </view>
    </block>
  </view>
  <!-- <view id="toView" class="test"></view> -->
</scroll-view>

<view class="pub-comment">
  <view class="pub-left">
    <input class="pub-input" bindinput="handleInput" value="{{inputValue}}"></input>
  </view>
  <view class="pub-button{{inputValue==''?'':'-with-text'}}" bindtap="publishMessage{{inputValue==''?'123':''}}">发送</view>
</view>