/* pages/register/register.wxss */
/* 与登录页共享 .login-page, .form-card, .input-group, .input-label, .input-box, .btn-area, .login-btn, .footer-tip */
/* 这些类定义在 login.wxss 中，小程序页面样式隔离下需要独立定义 */

.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F5F6F8 40%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.form-card {
  width: 600rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.08);
  margin-top: 60rpx;
  padding: 40rpx 40rpx 30rpx;
}

.input-group {
  display: flex;
  align-items: center;
  height: 100rpx;
  border-bottom: 1rpx solid #E8E8E8;
}

.input-group:last-of-type {
  border-bottom: none;
}

.input-label {
  color: #1A1A1A;
  font-size: 32rpx;
  font-weight: bold;
  width: 140rpx;
  flex-shrink: 0;
}

.input-box {
  flex: 1;
  margin-left: 20rpx;
}

.input-box input {
  font-size: 30rpx;
  color: #1A1A1A;
  width: 100%;
}

.btn-area {
  width: 600rpx;
  margin-top: 40rpx;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  background-color: #2E7D32;
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: bold;
  letter-spacing: 4px;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(46, 125, 50, 0.3);
}

.footer-tip {
  margin-top: 50rpx;
  font-size: 24rpx;
  color: #999999;
  text-align: center;
}
